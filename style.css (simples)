*{
box-sizing:border-box;
margin:0;
padding:0;
}

body{
font-family:system-ui;
padding:40px;
}

form{
display:flex;
flex-direction:column;
gap:15px;
max-width:500px;
}

input, textarea{
padding:10px;
font-size:16px;
}

button{
padding:10px;
background:#0077b5;
color:white;
border:none;
cursor:pointer;
}

button:hover{
background:#005582;
}

section{
margin-bottom:40px;
}
